# client/.env.local — local development override (gitignored via *.local)
# CRA reads .env.local BEFORE .env, so this overrides the production URL
REACT_APP_API_BASE_URL=http://localhost:5001/api

# client/.env — committed to git, used by Render for production builds
# This must always contain the PRODUCTION backend URL
# REACT_APP_API_BASE_URL=https://mern-portfolio-yasar.onrender.com/api
