node_modules/
dist/
build/
.DS_Store
Thumbs.db

# 🛡️ Environment Configuration
# We ignore the server .env because it contains your private MONGO_URI.
# To share the structure, use server/.env.example instead.
server/.env
*.local
*.secret

# 🌐 Frontend Environment
# We allow client/.env because it only contains the public backend URL.
!client/.env

# 📊 Logging & Debugging
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

